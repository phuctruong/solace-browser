{
  "id": "calendar-brief",
  "platform": "google-calendar",
  "version": "1.0.0",
  "description": "Navigate to Google Calendar, extract today's events and upcoming schedule, and produce a structured daily brief with time conflicts and free slots.",
  "oauth3_scopes": ["calendar.read.events", "local.evidence"],
  "evidence_type": "lane_a",
  "input_params": {
    "days_ahead": {
      "type": "integer",
      "description": "Number of days ahead to include. Default 1 (today only).",
      "required": false,
      "default": 1
    },
    "include_all_day": {
      "type": "boolean",
      "description": "Whether to include all-day events. Default true.",
      "required": false,
      "default": true
    }
  },
  "steps": [
    {
      "step": 1,
      "action": "load_session",
      "path": "artifacts/google_working_session.json",
      "description": "Load saved Google session cookies",
      "timeout_ms": 5000,
      "on_error": "fail"
    },
    {
      "step": 2,
      "action": "navigate",
      "target": "https://calendar.google.com/calendar/u/0/r/day",
      "wait_for": "[data-eventid], .Er4Fb, [role='main']",
      "timeout_ms": 12000,
      "screenshot": true,
      "description": "Navigate to Google Calendar day view",
      "on_error": "fail",
      "evidence_capture": {
        "type": "screenshot",
        "label": "calendar-day-view"
      }
    },
    {
      "step": 3,
      "action": "check_auth",
      "selector": "[role='main']",
      "fallback_url_pattern": "accounts.google.com",
      "description": "Verify Google authentication is active",
      "timeout_ms": 5000,
      "on_error": "fail"
    },
    {
      "step": 4,
      "action": "wait_for_selector",
      "selector": "[data-eventid], .NlL62b, [role='gridcell']",
      "timeout_ms": 8000,
      "description": "Wait for calendar events to render"
    },
    {
      "step": 5,
      "action": "extract_all",
      "selector": "[data-eventid]",
      "limit": 30,
      "fields": {
        "title": {"selector": "[data-eventchip] span, .FAxxKc", "type": "textContent"},
        "time_range": {"selector": "[data-eventchip] span:nth-child(2), .gVNoLb", "type": "textContent"},
        "location": {"selector": ".eNHLSb", "type": "textContent"},
        "calendar_name": {"selector": "[data-calendarid]", "type": "attribute", "attribute": "data-calendarid"},
        "is_all_day": {"check": "has_class", "class": "KF4T6b"},
        "event_id": {"type": "attribute", "attribute": "data-eventid"}
      },
      "description": "Extract all events from the day view",
      "screenshot": true,
      "on_error": "continue",
      "evidence_capture": {
        "type": "data_snapshot",
        "label": "events-extraction"
      }
    },
    {
      "step": 6,
      "action": "transform",
      "operations": [
        {
          "type": "parse_time_ranges",
          "field": "time_range",
          "output_fields": ["start_time", "end_time", "duration_minutes"]
        },
        {
          "type": "sort",
          "by": "start_time",
          "order": "ascending"
        },
        {
          "type": "detect_conflicts",
          "start_field": "start_time",
          "end_field": "end_time"
        },
        {
          "type": "compute_free_slots",
          "work_hours": {"start": "09:00", "end": "18:00"}
        }
      ],
      "description": "Parse times, detect conflicts, and compute free slots",
      "on_error": "continue"
    },
    {
      "step": 7,
      "action": "save_to_outbox",
      "filename": "calendar-brief-{date}.json",
      "description": "Save calendar brief to outbox for morning-brief consumption",
      "on_error": "fail",
      "evidence_capture": {
        "type": "output_hash",
        "label": "brief-saved"
      }
    },
    {
      "step": 8,
      "action": "return_result",
      "description": "Return structured calendar brief with events, conflicts, and free slots"
    }
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "events": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {"type": "string"},
            "start_time": {"type": "string"},
            "end_time": {"type": "string"},
            "duration_minutes": {"type": "integer"},
            "location": {"type": "string"},
            "is_all_day": {"type": "boolean"},
            "calendar_name": {"type": "string"}
          },
          "required": ["title", "start_time"]
        }
      },
      "conflicts": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "event_a": {"type": "string"},
            "event_b": {"type": "string"},
            "overlap_minutes": {"type": "integer"}
          }
        }
      },
      "free_slots": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "start": {"type": "string"},
            "end": {"type": "string"},
            "duration_minutes": {"type": "integer"}
          }
        }
      },
      "total_events": {"type": "integer"},
      "total_meetings_hours": {"type": "number"},
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["events", "total_events", "timestamp"]
  },
  "budgets": {
    "max_reads": 30,
    "max_sends": 0,
    "max_deletes": 0,
    "max_llm_calls": 0,
    "max_cost_per_run_usd": 0.01
  },
  "error_handling": {
    "on_auth_failure": "prompt_login",
    "on_timeout": "retry_once",
    "on_extraction_empty": "save_empty_brief",
    "max_retries": 1
  },
  "metadata": {
    "tags": ["calendar", "google", "daily-brief", "read-only", "extraction"],
    "difficulty": "easy",
    "estimated_duration_s": 10,
    "idempotent": true,
    "destructive": false
  }
}
