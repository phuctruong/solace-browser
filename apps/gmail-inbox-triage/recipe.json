{
  "id": "gmail-inbox-triage",
  "platform": "gmail",
  "version": "1.0.0",
  "description": "Scan Gmail inbox, extract email metadata, classify by priority using LLM, and present approval table with suggested actions.",
  "author": "Solace AGI",
  "rung": 641,
  "created": "2026-02-21",
  "updated": "2026-03-08",
  "oauth3_scopes": ["gmail.read", "gmail.modify", "local.evidence"],
  "evidence_type": "lane_a",

  "reasoning": {
    "research": "Gmail inbox renders email rows using role='row' ARIA elements. Each row contains subject (role='heading'), sender ([email] attribute), date, and read/starred indicators. Unread emails have class .zE (bold styling). After extraction, LLM classifies each email into priority buckets and suggests actions. User approves before any modifications.",
    "selector_strategy": "Use ARIA role selectors for stability. Role='row' for email list, role='heading' for subject. Fallback to class-based selectors for date and snippet. Gmail DOM is stable across updates for ARIA attributes.",
    "anti_bot_notes": "Read-only extraction phase has minimal bot detection risk. Navigate with saved session to avoid login. Wait for div[role='main'] to confirm page loaded. No rapid clicks or unusual navigation patterns.",
    "performance": "Expected run time: 15-30s (navigation 3s + wait 2s + extraction 2s + LLM classification 8-15s + rendering 1s). LLM called ONCE during preview — not during replay."
  },

  "input_params": {
    "limit": {
      "type": "integer",
      "description": "Maximum number of emails to scan. Default 20.",
      "required": false,
      "default": 20,
      "example": 50
    },
    "scan_window": {
      "type": "string",
      "description": "Time window to scan. Default last_24h.",
      "required": false,
      "default": "last_24h",
      "enum": ["last_1h", "last_24h", "last_7_days", "last_30_days", "all"]
    },
    "include_read": {
      "type": "boolean",
      "description": "Include already-read emails in triage. Default false.",
      "required": false,
      "default": false
    }
  },

  "steps": [
    {
      "step": 1,
      "action": "load_session",
      "path": "artifacts/gmail_working_session.json",
      "description": "Load saved Gmail session cookies",
      "timeout_ms": 5000,
      "screenshot": false
    },
    {
      "step": 2,
      "action": "navigate",
      "target": "https://mail.google.com/mail/u/0/#inbox",
      "wait_for": "div[role='main']",
      "timeout_ms": 10000,
      "screenshot": true,
      "description": "Navigate to Gmail inbox and wait for main container"
    },
    {
      "step": 3,
      "action": "check_auth",
      "selector": "div[role='main']",
      "fallback_url_pattern": "accounts.google.com",
      "description": "Verify Gmail authentication is active — if redirected to login, abort with SESSION_EXPIRED",
      "timeout_ms": 5000,
      "screenshot": false
    },
    {
      "step": 4,
      "action": "wait_for_selector",
      "selector": "[role='row']",
      "timeout_ms": 8000,
      "description": "Wait for email rows to render in inbox"
    },
    {
      "step": 5,
      "action": "extract_all",
      "selector": "[role='row']",
      "limit": "{params.limit}",
      "fields": {
        "subject": {
          "selector": "[role='heading']",
          "type": "textContent"
        },
        "sender": {
          "selector": "[email]",
          "type": "attribute",
          "attribute": "email"
        },
        "sender_name": {
          "selector": "[email]",
          "type": "textContent"
        },
        "date": {
          "selector": "td.xW.xY span",
          "type": "textContent"
        },
        "snippet": {
          "selector": ".y2",
          "type": "textContent"
        },
        "is_read": {
          "check": "not_has_class",
          "class": "zE"
        },
        "is_starred": {
          "selector": "span[aria-label*='Starred']",
          "type": "exists"
        },
        "has_attachment": {
          "selector": "div.yf.xY span.aV3",
          "type": "exists"
        }
      },
      "description": "Extract email metadata from visible inbox rows",
      "screenshot": true
    },
    {
      "step": 6,
      "action": "llm_classify",
      "prompt_file": "inbox/prompts/triage-prompt.md",
      "input_variable": "emails",
      "model_preference": ["claude-haiku-4-5-20251001", "gemini-2.5-flash", "gpt-4.1-mini"],
      "categories": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "ARCHIVE", "SKIP"],
      "max_tokens": 4000,
      "temperature": 0.1,
      "description": "Classify each email by priority using LLM with uplift-enriched prompt",
      "budget_check": true,
      "evidence_capture": true
    },
    {
      "step": 7,
      "action": "sort",
      "by": "priority",
      "order": "desc",
      "priority_map": {
        "CRITICAL": 5,
        "HIGH": 4,
        "MEDIUM": 3,
        "LOW": 2,
        "ARCHIVE": 1,
        "SKIP": 0
      },
      "description": "Sort emails by priority descending (CRITICAL first)"
    },
    {
      "step": 8,
      "action": "present",
      "type": "approval_table",
      "columns": [
        "priority",
        "sender",
        "subject",
        "snippet",
        "suggested_action",
        "draft_reply",
        "confidence"
      ],
      "description": "Present categorized emails as approval table in sidebar. User reviews and approves/rejects each action.",
      "approval_required": true,
      "timeout_minutes": 60
    },
    {
      "step": 9,
      "action": "execute_approved",
      "actions": {
        "draft_reply": {
          "recipe": "gmail-draft-reply",
          "requires_scope": "gmail.modify"
        },
        "archive": {
          "recipe": "gmail-archive-emails",
          "requires_scope": "gmail.modify"
        },
        "label": {
          "recipe": "gmail-label-emails",
          "requires_scope": "gmail.modify"
        },
        "flag": {
          "action": "star",
          "requires_scope": "gmail.modify"
        },
        "snooze": {
          "action": "snooze",
          "requires_scope": "gmail.modify"
        },
        "skip": {
          "action": "noop"
        }
      },
      "description": "Execute only the actions the user approved in step 8",
      "evidence_capture": true
    },
    {
      "step": 10,
      "action": "seal_evidence",
      "hash_algorithm": "sha256",
      "include": ["extraction", "classification", "approvals", "actions", "screenshots"],
      "description": "Seal evidence bundle with hash chain for Part 11 compliance"
    },
    {
      "step": 11,
      "action": "return_result",
      "description": "Return triage summary with evidence hash"
    }
  ],

  "output_schema": {
    "type": "object",
    "properties": {
      "emails": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "subject": {"type": "string"},
            "sender": {"type": "string"},
            "sender_name": {"type": "string"},
            "date": {"type": "string"},
            "snippet": {"type": "string"},
            "is_read": {"type": "boolean"},
            "is_starred": {"type": "boolean"},
            "has_attachment": {"type": "boolean"},
            "classification": {"type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "ARCHIVE", "SKIP"]},
            "confidence": {"type": "integer", "minimum": 1, "maximum": 10},
            "reason": {"type": "string"},
            "suggested_action": {"type": "string"},
            "draft_reply": {"type": ["string", "null"]},
            "threats_detected": {"type": "array", "items": {"type": "string"}},
            "approved": {"type": ["boolean", "null"]}
          },
          "required": ["subject", "sender", "is_read", "classification", "confidence"]
        }
      },
      "total_extracted": {"type": "integer"},
      "total_classified": {"type": "integer"},
      "breakdown": {
        "type": "object",
        "properties": {
          "critical": {"type": "integer"},
          "high": {"type": "integer"},
          "medium": {"type": "integer"},
          "low": {"type": "integer"},
          "archive": {"type": "integer"},
          "skip": {"type": "integer"}
        }
      },
      "actions_taken": {"type": "integer"},
      "evidence_hash": {"type": "string"},
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["emails", "total_extracted", "total_classified", "evidence_hash", "timestamp"]
  },

  "expected_evidence": {
    "screenshots": true,
    "html_snapshots": true,
    "action_log": true,
    "agency_token": true,
    "selector_matches": true,
    "llm_prompt": true,
    "llm_response": true,
    "approval_log": true
  },

  "error_handling": {
    "session_expired": "Detect accounts.google.com redirect — abort with SESSION_EXPIRED error",
    "empty_inbox": "Return empty emails array with total_extracted=0 — not an error",
    "selector_timeout": "Retry once with 15s timeout, then abort with SELECTOR_TIMEOUT",
    "llm_budget_exceeded": "Abort classification, return raw extraction without LLM labels",
    "llm_timeout": "Retry once with doubled timeout, then present raw extraction for manual triage",
    "approval_timeout": "Auto-cancel unapproved actions after timeout_minutes, seal evidence"
  },

  "metadata": {
    "tags": ["gmail", "inbox", "triage", "classification", "priority", "draft-reply", "approval"],
    "difficulty": "medium",
    "prerequisites": ["gmail_session"],
    "cloud_run_ready": true,
    "estimated_duration_s": 25,
    "idempotent": true,
    "destructive": false,
    "approval_required": true,
    "replay_cost_usd": 0.001
  }
}
