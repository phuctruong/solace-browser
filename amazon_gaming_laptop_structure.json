          "purpose": "filter by product rating"
        },
        {
          "filter_name": "memory",
          "selector": "[data-a-expander-name*='RAM']",
          "type": "checkbox_list",
          "purpose": "filter by RAM capacity"
        },
        {
          "filter_name": "processor",
          "selector": "[data-a-expander-name*='Processor']",
          "type": "checkbox_list",
          "purpose": "filter by CPU type"
        },
        {
          "filter_name": "graphics",
          "selector": "[data-a-expander-name*='Graphics']",
          "type": "checkbox_list",
          "purpose": "filter by GPU type"
        }
      ]
