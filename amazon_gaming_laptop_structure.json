    {
      "section_id": "product_grid",
      "name": "product_results",
      "position": "center_main",
      "selector": "[data-component-type='s-search-results']",
      "type": "grid",
      "purpose": "display product listings",
      "layout": "multi_column_grid",
      "sub_elements": [
        {
          "element_name": "product_card",
          "selector": "[data-component-type='s-search-result']",
          "type": "product_item",
          "purpose": "individual product listing",
          "data_attributes": [
            "data-asin",
            "data-index",
            "data-uuid",
            "data-component-id"
          ],
          "child_elements": [
            {
              "name": "product_image",
              "selector": "img.s-image",
              "type": "image",
              "purpose": "display product thumbnail"
            },
            {
              "name": "product_title",
              "selector": "h2 a span",
              "type": "text_link",
              "purpose": "product name and link to detail page"
            },
            {
              "name": "rating_stars",
              "selector": "[aria-label*='stars']",
              "type": "star_rating",
              "purpose": "display average rating"
            },
            {
              "name": "review_count",
              "selector": ".s-size-mini",
              "type": "text",
              "purpose": "number of reviews"
            },
            {
              "name": "price",
              "selector": ".a-price-whole",
              "type": "text",
              "purpose": "product price"
            },
            {
              "name": "prime_badge",
              "selector": ".s-prime",
              "type": "badge",
              "purpose": "indicate Prime eligibility"
            },
            {
              "name": "sponsored_badge",
              "selector": ".s-sponsored-label",
              "type": "badge",
              "purpose": "indicate sponsored product"
            }
          ]
        }
      ],
      "item_count_observed": 16,
      "item_count_typical": "35+",
      "pagination_available": true
    },
    {
      "section_id": "pagination",
