      "elements": [
        {
          "name": "next_page",
          "selector": ".s-pagination-next",
          "type": "button",
          "purpose": "load next page of results"
        },
        {
          "name": "page_numbers",
          "selector": ".s-pagination-item",
          "type": "button_list",
          "purpose": "jump to specific page"
        }
      ]
