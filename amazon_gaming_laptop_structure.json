            "Featured",
            "Price: Low to High",
            "Price: High to Low",
            "Avg. Customer Review",
            "Newest Arrivals"
          ]
        },
        {
          "element_name": "results_per_page",
          "selector": "[aria-label*='Items per page']",
          "type": "dropdown",
          "purpose": "control pagination size"
        }
