{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "package": {
    "productName": "Solace Hub",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true,
        "setTitle": true,
        "setFocus": true,
        "setSize": true,
        "setMinSize": true,
        "center": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.solaceagi.hub",
      "icon": [
        "icons/yinyang-logo.png"
      ],
      "shortDescription": "Solace Hub — AI Worker Platform Desktop Orchestrator",
      "longDescription": "Solace Hub manages the Yinyang Server lifecycle, browser sessions, schedules, billing, and evidence chain for the Solace AI Worker Platform.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8888; connect-src * http://localhost:8888 https://solaceagi.com; img-src * data: blob:; style-src 'self' 'unsafe-inline' http://localhost:8888; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:8888; font-src 'self' data:"
    },
    "systemTray": {
      "iconPath": "icons/yinyang-logo.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "label": "main",
        "title": "Solace Hub",
        "width": 1400,
        "height": 1200,
        "minWidth": 800,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "center": true,
        "url": "index.html"
      }
    ]
  }
}
