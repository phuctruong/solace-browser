  "description": "Add LinkedIn project with optimized performance (2.73x faster than baseline)",

  "reasoning": {
    "research": "LinkedIn project forms use both standard inputs (name field) and contenteditable divs (description field). Standard .fill() works for inputs but times out on contenteditable.",

    "openclaw_solution": "Found in ~/projects/openclaw - use 'slowly' pattern: click → select all → type with delay. This works around React's form validation.",

    "performance_analysis": "Baseline: 28.82s per project. Bottleneck: slowly typing at 50ms/char = 12.92s for 200 chars. Optimization: reduce to 15ms/char = 4.30s (3x faster).",

    "strategy": "Use role selectors for stability + optimized slowly typing (15ms delay) + remove arbitrary sleeps. Total speedup: 2.73x.",

    "llm_learnings": "For LinkedIn forms: (1) Use role=textbox[name='Project name*'] for name field (fast fill), (2) Use role=textbox[name='Description'] for description (slowly with delay=15), (3) Remove sleeps between actions (page ready when API returns), (4) Use role=button[name='Save'] to submit"
  },

  "portals": {
    "projects_page": {
      "to_add_form": {
        "selector": "role=link[name='Add new project']",
        "type": "click",
        "strength": 0.95,
        "wait_after_ms": 500,
        "note": "Link, not button! Common mistake."
      }
    },

    "add_form": {
      "name_field": {
        "selector": "role=textbox[name='Project name*']",
        "type": "fill",
        "method": "standard_fill",
        "strength": 1.0
      },

      "description_field": {
        "selector": "role=textbox[name='Description']",
        "type": "fill_slowly",
        "method": "click_select_type",
        "delay_ms": 15,
        "strength": 0.98,
        "note": "Contenteditable - requires slowly pattern"
      },

      "save_button": {
        "selector": "role=button[name='Save']",
        "type": "click",
        "strength": 1.0,
        "wait_after_ms": 1000
      }
    }
  },

