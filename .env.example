# SOLACE BROWSER - CREDENTIAL SETUP GUIDE
# Copy this file to .env and fill in your actual credentials
#
# IMPORTANT: .env is in .gitignore - it will NEVER be committed to git
# SECURITY: Never share your .env file or commit it to version control

# Gmail Credentials
# For Gmail, use an App Password (not your regular password):
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or other device)
# 3. Copy the 16-character password
GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=your-app-password-here

# LinkedIn Credentials
# Use your regular LinkedIn password (or LinkedIn app password if you have one)
# SECURITY: If this is a shared account, use a service account with limited permissions
LINKEDIN_EMAIL=your-email@linkedin.com
LINKEDIN_PASSWORD=your-password-here

# Google Credentials (if different from Gmail)
# Usually same as Gmail, but can be different for service accounts
GOOGLE_EMAIL=your-email@gmail.com
GOOGLE_PASSWORD=your-app-password-here

# (Optional) Proxy Settings
# PROXY_URL=http://proxy.company.com:8080
# PROXY_USERNAME=username
# PROXY_PASSWORD=password

# (Optional) Browser Settings
# BROWSER_HEADLESS=true
# BROWSER_PORT=9223
