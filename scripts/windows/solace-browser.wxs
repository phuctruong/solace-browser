<?xml version="1.0" encoding="UTF-8"?>
<!--
  solace-browser.wxs — WiX v4 MSI installer for Solace Browser + Solace Hub (Windows)
  Auth: 65537 | Legacy debug port permanently banned

  Build:
    wix build -src scripts/windows/solace-browser.wxs -src dist/windows-bundle-files.wxs \
              -out dist/solace-browser-windows-x86_64.msi \
              -d BundleDir=dist/solace-browser-release-windows
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Solace Browser"
    Manufacturer="Solace AI"
    Version="1.0.0"
    UpgradeCode="A5C2F4D7-3B8E-4A91-B6C0-2D7F1E9A4B83"
    Scope="perMachine"
    Compressed="yes"
    InstallerVersion="500">

    <!-- Upgrade logic: remove older versions before install -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Solace Browser is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Solace Browser" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="BundleFiles" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>
  </Package>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Solace Browser" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Solace Browser" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="B7D3E2A1-9C4F-4D81-A0B5-3E8C6F2D1A94">
        <File
          Id="SolaceHubExe"
          Source="!(bind.Variable.BundleDir)\solace-hub.exe"
          Name="solace-hub.exe"
          KeyPath="yes" />
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Solace Browser"
          Name="InstallDir"
          Value="[INSTALLFOLDER]"
          Type="string"
          KeyPath="no" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="C8E4F3B2-0D5A-4E92-B1C6-4F9D7A3E2B05">
        <Shortcut
          Id="StartMenuShortcutEntry"
          Name="Solace Browser"
          Description="Hub-first Browser runtime for Solace"
          Target="[INSTALLFOLDER]solace-hub.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <Shortcut
          Id="DesktopShortcutEntry"
          Directory="DesktopFolder"
          Name="Solace Browser"
          Description="Hub-first Browser runtime for Solace"
          Target="[INSTALLFOLDER]solace-hub.exe"
          WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupStartMenu" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="SOFTWARE\Solace Browser\Shortcuts"
          Name="installed"
          Value="1"
          Type="integer"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
