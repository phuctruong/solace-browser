    "dm_composer_input": {
      "selector": "div[data-testid='dmComposerTextInput'][contenteditable='true']",
      "confidence": 0.92,
      "action": "click_then_human_type",
      "typing_delay_ms": "60-120",
      "note": "DM message compose contenteditable div"
    },
    "dm_send_button": {
      "selector": "button[data-testid='dmComposerSendButton']",
      "fallback_selector": "button[aria-label='Send'], button[type='submit'][aria-label*='Send']",
      "confidence": 0.92,
      "action": "click",
      "wait_after_ms": 3000,
      "note": "Send button in DM composer"
    },
    "dm_restricted_notice": {
      "selector": "span:has-text('limits who can message'), div[data-testid='dm-restricted']",
      "confidence": 0.82,
      "type": "exists",
      "optional": true,
      "note": "Indicates target user has DMs restricted — abort with DM_RESTRICTED"
    }
  },

