      "confidence": 0.88,
      "action": "click",
      "wait_after_ms": 1500,
      "note": "Compose new DM — opens recipient search modal"
    },
    "recipient_search_input": {
      "selector": "input[data-testid='searchPeople'], input[placeholder*='Search people'], input[aria-label*='Search people']",
      "confidence": 0.88,
      "action": "click_then_human_type",
      "typing_delay_ms": "80-150",
      "note": "Recipient search field in DM compose modal"
    },
    "typeahead_user_result": {
      "selector": "div[data-testid='TypeaheadUser']:first-child, li[data-testid='UserCell']:first-child",
      "fallback_selector": "div[role='option'][data-testid*='User']:first-child",
      "confidence": 0.87,
      "action": "click",
      "wait_after_ms": 1000,
      "note": "First search result in recipient typeahead dropdown"
    },
    "next_button": {
      "selector": "button[data-testid='nextButton'], button:has-text('Next'), button[aria-label='Next']",
      "confidence": 0.88,
      "action": "click",
      "wait_after_ms": 1500
