  "messages": {
    "dm_drawer": {
      "selector": "div[data-testid='DMDrawer'], div[aria-label='Direct Messages']",
      "confidence": 0.90,
      "type": "wait_for",
      "note": "Messages panel — confirms messages section loaded"
    },
    "new_dm_button": {
      "selector": "a[data-testid='NewDM_Button'], button[aria-label='New message'], button[data-testid='NewDM_Button']",
