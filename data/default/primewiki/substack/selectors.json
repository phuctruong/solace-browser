{
  "node_id": "substack-selectors",
  "version": "1.0.0",
  "platform": "substack",
  "domain": "substack.com",
  "authority": 65537,
  "created": "2026-02-21",
  "source": "substack-automation-recipes.primewiki.md",

  "dashboard": {
    "main_container": {
      "selector": "div[data-component='DashboardPage']",
      "confidence": 0.92,
      "type": "wait_for",
      "note": "Primary dashboard wrapper — confirms authenticated state"
    },
    "new_post_button": {
      "selector": "a[href*='/publish/post'], button[data-testid='new-post-button'], a[data-testid='new-post-button']",
      "confidence": 0.90,
      "action": "click",
      "wait_after_ms": 3000,
      "note": "Opens the post editor — most stable via data-testid"
    },
    "navigation_links": {
      "selector": "nav[aria-label='Dashboard navigation'] a",
      "confidence": 0.88,
      "type": "selector_list"
    }
  },

  "editor": {
    "title_field": {
      "selector": "div[data-testid='post-title'], input[placeholder*='Title'], h1[data-placeholder*='Title']",
      "confidence": 0.90,
      "action": "click_then_human_type",
      "typing_delay_ms": "80-150",
      "note": "ProseMirror title block or dedicated input — check which variant is rendered"
    },
    "subtitle_field": {
      "selector": "div[data-testid='post-subtitle'], input[placeholder*='Subtitle'], h2[data-placeholder*='Subtitle'], p[data-placeholder*='Add a subtitle']",
      "confidence": 0.88,
      "action": "click_then_human_type",
      "typing_delay_ms": "50-120",
      "note": "Optional subtitle / deck field below title"
    },
    "body_field": {
      "selector": "div.ProseMirror[contenteditable='true']",
      "confidence": 0.95,
      "action": "click_then_type",
      "typing_delay_ms": 50,
      "note": "Main ProseMirror editor body — same selector across Substack versions"
    },
    "publish_button": {
      "selector": "button[data-testid='publish-button'], button:has-text('Publish'), button[aria-label*='Publish']",
      "confidence": 0.88,
      "action": "click",
      "wait_after_ms": 2000,
      "note": "Opens publish options dialog"
    },
    "confirm_publish_button": {
      "selector": "button[data-testid='confirm-publish'], button:has-text('Publish now'), button[aria-label='Publish now']",
      "fallback_selector": "button:has-text('Publish post')",
      "confidence": 0.85,
      "action": "click",
      "wait_after_ms": 4000,
      "note": "Final confirmation button inside publish dialog"
    },
    "schedule_later_option": {
      "selector": "button:has-text('Schedule for later'), a:has-text('Schedule'), button[data-testid='schedule-option']",
      "fallback_selector": "li:has-text('Schedule'), div[role='menuitem']:has-text('Schedule')",
      "confidence": 0.85,
      "action": "click",
      "wait_after_ms": 1500,
      "note": "Schedule option inside publish dropdown/dialog"
    },
    "schedule_datetime_input": {
      "selector": "input[type='datetime-local']",
      "fallback_selector": "input[data-testid='schedule-date-input'], input[type='date']",
      "confidence": 0.88,
      "action": "fill",
      "note": "Datetime picker — direct value fill acceptable (no bot detection on datetime inputs)"
    },
    "confirm_schedule_button": {
      "selector": "button[data-testid='confirm-schedule'], button:has-text('Schedule post'), button:has-text('Schedule')",
      "fallback_selector": "button.schedule-confirm, button[aria-label*='Schedule']",
      "confidence": 0.85,
      "action": "click",
      "wait_after_ms": 3000
    },
    "update_button": {
      "selector": "button[data-testid='update-button'], button:has-text('Update'), button:has-text('Save')",
      "fallback_selector": "button.update-btn, button[data-component='UpdateButton']",
      "confidence": 0.84,
      "action": "click",
      "wait_after_ms": 3000,
      "note": "Save/Update button for editing published posts"
    },
    "audience_everyone": {
      "selector": "input[value='everyone'], label:has-text('Everyone'), button[data-audience='everyone']",
      "confidence": 0.85,
      "action": "click",
      "note": "Select free/everyone audience in publish dialog"
    },
    "audience_paid": {
      "selector": "input[value='paid'], label:has-text('Paid'), button[data-audience='paid']",
      "confidence": 0.85,
      "action": "click",
      "note": "Select paid-only audience in publish dialog"
    }
  },

  "posts_list": {
    "page_container": {
      "selector": "div[data-component='PostsPage']",
      "confidence": 0.90,
      "type": "wait_for"
    },
    "post_rows": {
      "selector": "tr.post-row, div[data-testid='post-card'], div.post-item",
      "confidence": 0.87,
      "type": "selector_list",
      "note": "Each row/card represents one post"
    },
    "post_edit_link": {
      "selector": "a[data-testid='edit-post'], a[aria-label*='Edit'], button:has-text('Edit')",
      "confidence": 0.86,
      "action": "click",
      "note": "Edit link per post row — click within the matching row context"
    },
    "post_comments_link": {
      "selector": "a[data-testid='view-comments'], a[href*='/comments'], button:has-text('Comments')",
      "confidence": 0.84,
      "action": "click",
      "note": "Link to view comments for a specific post"
    },
    "post_title_text": {
      "selector": "a.post-title, td.post-name, h3.post-title",
      "confidence": 0.88,
      "type": "text_extraction",
      "note": "Post title text inside a row/card for matching"
    }
  },

