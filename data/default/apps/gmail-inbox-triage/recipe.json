{
  "id": "gmail-inbox-triage",
  "platform": "gmail",
  "version": "1.0.0",
  "description": "Scan Gmail inbox, extract email metadata, and prioritize messages.",
  "oauth3_scopes": ["gmail.read.inbox", "gmail.draft.create"],
  "evidence_type": "lane_a",
  "input_params": {
    "limit": {
      "type": "integer",
      "description": "Maximum number of emails to scan. Default 20.",
      "required": false,
      "default": 20
    }
  },
  "steps": [
    {
      "step": 1,
      "action": "load_session",
      "path": "artifacts/gmail_working_session.json",
      "description": "Load saved Gmail session cookies",
      "timeout_ms": 5000
    },
    {
      "step": 2,
      "action": "navigate",
      "target": "https://mail.google.com/mail/u/0/#inbox",
      "wait_for": "div[role='main']",
      "timeout_ms": 10000,
      "screenshot": true,
      "description": "Navigate to Gmail inbox"
    },
    {
      "step": 3,
      "action": "check_auth",
      "selector": "div[role='main']",
      "fallback_url_pattern": "accounts.google.com",
      "description": "Verify Gmail authentication is active",
      "timeout_ms": 5000
    },
    {
      "step": 4,
      "action": "wait_for_selector",
      "selector": "[role='row']",
      "timeout_ms": 8000,
      "description": "Wait for email rows to render"
    },
    {
      "step": 5,
      "action": "extract_all",
      "selector": "[role='row']",
      "limit": "{params.limit}",
      "fields": {
        "subject": {"selector": "[role='heading']", "type": "textContent"},
        "sender": {"selector": "[email]", "type": "attribute", "attribute": "email"},
        "sender_name": {"selector": "[email]", "type": "textContent"},
        "date": {"selector": "td.xW.xY span", "type": "textContent"},
        "snippet": {"selector": ".y2", "type": "textContent"},
        "is_read": {"check": "not_has_class", "class": "zE"},
        "is_starred": {"selector": "span[aria-label*='Starred']", "type": "exists"}
      },
      "description": "Extract email metadata from inbox rows",
      "screenshot": true
    },
    {
      "step": 6,
      "action": "return_result",
      "description": "Return extracted emails as structured data"
    }
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "emails": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "subject": {"type": "string"},
            "sender": {"type": "string"},
            "sender_name": {"type": "string"},
            "date": {"type": "string"},
            "snippet": {"type": "string"},
            "is_read": {"type": "boolean"},
            "is_starred": {"type": "boolean"}
          },
          "required": ["subject", "sender", "is_read"]
        }
      },
      "total_extracted": {"type": "integer"},
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["emails", "total_extracted", "timestamp"]
  },
  "metadata": {
    "tags": ["gmail", "inbox", "triage", "read-only", "extraction"],
    "difficulty": "easy",
    "estimated_duration_s": 10,
    "idempotent": true,
    "destructive": false
  }
}
