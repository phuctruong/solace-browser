{
  "id": "claude-uplift",
  "platform": "claude",
  "version": "1.0.0",
  "description": "Inject prime uplift skills into Claude.ai conversation, then send a review prompt and capture the uplifted response. Skills are loaded from inbox/skills/ as inline context.",
  "author": "65537",
  "rung": 641,
  "created": "2026-03-07",
  "oauth3_scopes": ["claude.read.conversation", "claude.draft.message", "local.evidence"],
  "evidence_type": "lane_a",

  "reasoning": {
    "research": "Claude.ai uses a ProseMirror contenteditable editor. Responses render in message containers. Claude provides the most thorough security analysis and the most precise code suggestions. Tends to be the strictest scorer (90 in R5 vs Gemini 95).",
    "uplift_theory": "Claude responds exceptionally well to constraints (P13) and negative space (P16). The Mike West/Linus Torvalds personas align with Claude's training on security and code quality. Expected quality improvement: 30-50%.",
    "selector_strategy": "Input: .ProseMirror (contenteditable). Send: button[aria-label='Send message']. Response: [data-testid='chat-message-content'] or div with longest innerText. Streaming: [data-is-streaming] attribute. Injection: base64 encode + chunked insertText.",
    "saved_reasoning": "Claude.ai cannot browse URLs (unlike ChatGPT/Gemini) — it evaluates based on injected text only. This makes the uplift injection MORE important for Claude since it has no other context source. Claude's strictest scoring provides the best negative-space coverage."
  },

  "input_params": {
    "task_type": {
      "type": "string",
      "description": "Type of review: architecture, code, ux, business, security",
      "required": true,
      "enum": ["architecture", "code", "ux", "business", "security"],
      "default": "architecture"
    },
    "review_content": {
      "type": "string",
      "description": "The content to review",
      "required": true
    },
    "project_context": {
      "type": "string",
      "description": "Project-specific context to include",
      "required": false,
      "default": ""
    },
    "conversation_id": {
      "type": "string",
      "description": "Existing conversation tab page_id for follow-up rounds",
      "required": false,
      "default": ""
    },
    "round": {
      "type": "integer",
      "description": "Review round number (1 = inject uplift + full prompt, 2+ = delta only)",
      "required": false,
      "default": 1
    }
  },

  "steps": [
    {
      "step": 1,
      "action": "load_session",
      "path": "artifacts/claude_working_session.json",
      "description": "Load saved Claude.ai session cookies",
      "timeout_ms": 5000
    },
    {
      "step": 2,
      "action": "conditional",
      "condition": "{params.conversation_id} == ''",
      "if_true": {
        "action": "navigate",
        "target": "https://claude.ai/new",
        "wait_for": ".ProseMirror, [contenteditable='true']",
        "timeout_ms": 15000,
        "description": "Navigate to Claude.ai for new conversation"
      },
      "if_false": {
        "action": "activate_tab",
        "page_id": "{params.conversation_id}",
        "description": "Reuse existing conversation tab"
      }
    },
    {
      "step": 3,
      "action": "check_auth",
      "selector": ".ProseMirror, [contenteditable='true']",
      "fallback_url_pattern": "claude.ai/login",
      "description": "Verify Claude.ai authentication active"
    },
    {
      "step": 4,
      "action": "conditional",
      "condition": "{params.round} == 1",
      "if_true": {
        "action": "compose_uplift",
        "skills_dir": "inbox/skills/",
        "template": "inbox/templates/{params.task_type}-review.md",
        "persona_key": "{params.task_type}",
        "project_context": "{params.project_context}",
        "output_var": "uplift_message"
      },
      "if_false": {"action": "noop"}
    },
    {
      "step": 5,
      "action": "conditional",
      "condition": "{params.round} == 1",
      "if_true": {
        "action": "inject_text",
        "selector": ".ProseMirror",
        "text": "{uplift_message}",
        "method": "base64_chunked_insert",
        "chunk_size": 4000,
        "chunk_delay_ms": 100,
        "description": "Inject uplift skills into Claude.ai"
      },
      "if_false": {"action": "noop"}
    },
    {
      "step": 6,
      "action": "conditional",
      "condition": "{params.round} == 1",
      "if_true": {
        "action": "click",
        "selector": "button[aria-label='Send message']",
        "timeout_ms": 5000
      },
      "if_false": {"action": "noop"}
    },
    {
      "step": 7,
      "action": "conditional",
      "condition": "{params.round} == 1",
      "if_true": {
        "action": "wait_for_stable",
        "selector": "[data-testid='chat-message-content']:last-child, div.font-claude-message:last-child",
        "stability_ms": 3000,
        "timeout_ms": 30000,
        "description": "Wait for Claude to acknowledge uplift"
      },
      "if_false": {"action": "noop"}
    },
    {
      "step": 8,
      "action": "inject_text",
      "selector": ".ProseMirror",
      "text": "{params.review_content}",
      "method": "base64_chunked_insert",
      "chunk_size": 4000,
      "chunk_delay_ms": 100,
      "description": "Inject the review content"
    },
    {
      "step": 9,
      "action": "click",
      "selector": "button[aria-label='Send message']",
      "timeout_ms": 5000,
      "screenshot": true
    },
    {
      "step": 10,
      "action": "wait_for_stable",
      "selector": "[data-testid='chat-message-content']:last-child, div.font-claude-message:last-child",
      "stability_ms": 5000,
      "timeout_ms": 180000,
      "description": "Wait for Claude to finish the review",
      "screenshot": true
    },
    {
      "step": 11,
      "action": "extract",
      "selector": "[data-testid='chat-message-content']:last-child, div.font-claude-message:last-child",
      "fields": {
        "response_text": {"selector": "self", "type": "textContent"},
        "response_html": {"selector": "self", "type": "innerHTML"},
        "has_code_blocks": {"selector": "pre code, code", "type": "exists"}
      },
      "description": "Extract the uplifted review response"
    },
    {
      "step": 12,
      "action": "save_to_outbox",
      "path": "outbox/responses/",
      "filename": "claude-r{params.round}-{timestamp}.json",
      "data": {
        "llm": "claude",
        "round": "{params.round}",
        "task_type": "{params.task_type}",
        "response_text": "{response_text}",
        "response_html": "{response_html}",
        "conversation_url": "{current_url}",
        "page_id": "{current_page_id}",
        "timestamp": "{timestamp}"
      }
    },
    {
      "step": 13,
      "action": "hash_evidence",
      "algorithm": "sha256",
      "inputs": ["{params.review_content}", "{response_text}", "{timestamp}"],
      "output_path": "outbox/evidence/claude-r{params.round}-{timestamp}.json"
    },
    {
      "step": 14,
      "action": "return_result",
      "output": {
        "status": "reviewed",
        "llm": "claude",
        "round": "{params.round}",
        "task_type": "{params.task_type}",
        "response_text": "{response_text}",
        "conversation_url": "{current_url}",
        "page_id": "{current_page_id}",
        "evidence_hash": "{evidence_hash}",
        "skills_loaded": ["prime-safety", "prime-coder", "fallback-ban", "negative-space", "browser-domain", "constraints", "stakes"]
      }
    }
  ],

  "output_schema": {
    "type": "object",
    "properties": {
      "status": {"type": "string", "enum": ["reviewed", "failed", "partial"]},
      "llm": {"type": "string"},
      "round": {"type": "integer"},
      "task_type": {"type": "string"},
      "response_text": {"type": "string"},
      "conversation_url": {"type": "string"},
      "page_id": {"type": "string"},
      "evidence_hash": {"type": "string"},
      "skills_loaded": {"type": "array", "items": {"type": "string"}}
    }
  },

  "metadata": {
    "tags": ["claude", "uplift", "cross-llm-qa", "architecture-review", "code-review", "skills"],
    "difficulty": "medium",
    "prerequisites": ["claude_session"],
    "cloud_run_ready": true,
    "estimated_duration_s": 120,
    "idempotent": true,
    "destructive": false,
    "chain_with": ["chatgpt-uplift", "gemini-uplift"]
  }
}
