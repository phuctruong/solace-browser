{
  "id": "weekly-digest",
  "platform": "multi-site",
  "version": "1.0.0",
  "type": "orchestrator",
  "description": "Collect five days of morning briefs, focus session logs, price tracking data, and script drafts, then synthesize a comprehensive weekly review with trends, achievements, and next-week priorities.",
  "oauth3_scopes": ["local.evidence"],
  "evidence_type": "lane_a",
  "input_params": {
    "week_start": {
      "type": "string",
      "description": "Start date of the week (ISO format). Default: auto-detect current week Monday.",
      "required": false,
      "default": "auto"
    },
    "include_focus_stats": {
      "type": "boolean",
      "description": "Whether to include focus timer statistics. Default true.",
      "required": false,
      "default": true
    }
  },
  "steps": [
    {
      "step": 1,
      "action": "record_timestamp",
      "field": "digest_start",
      "description": "Record digest generation start time",
      "timeout_ms": 1000,
      "on_error": "fail"
    },
    {
      "step": 2,
      "action": "load_outbox_range",
      "app_id": "morning-brief",
      "pattern": "morning-brief-{week_dates}.json",
      "days": 5,
      "description": "Load the past 5 days of morning briefs from the outbox",
      "timeout_ms": 10000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "data_snapshot",
        "label": "weekly-morning-briefs"
      }
    },
    {
      "step": 3,
      "action": "load_outbox_range",
      "app_id": "focus-timer",
      "pattern": "focus-sessions-log.json",
      "description": "Load focus timer session history for the week",
      "timeout_ms": 5000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "data_snapshot",
        "label": "weekly-focus-data"
      }
    },
    {
      "step": 4,
      "action": "load_outbox_range",
      "app_id": "amazon-price-tracker",
      "pattern": "amazon-prices-{week_dates}.json",
      "days": 5,
      "description": "Load price tracking snapshots from the week",
      "timeout_ms": 5000,
      "on_error": "continue"
    },
    {
      "step": 5,
      "action": "load_outbox_range",
      "app_id": "youtube-script-writer",
      "pattern": "youtube-script-{week_dates}.json",
      "days": 5,
      "description": "Load any script drafts produced this week",
      "timeout_ms": 5000,
      "on_error": "continue"
    },
    {
      "step": 6,
      "action": "transform",
      "operations": [
        {
          "type": "aggregate_daily_briefs",
          "fields": ["urgent_items", "top_actions", "data_sources_summary"],
          "output": "week_summary"
        },
        {
          "type": "compute_focus_stats",
          "fields": ["actual_duration_minutes", "task_label", "completed"],
          "output": "focus_stats"
        },
        {
          "type": "compute_price_trends",
          "fields": ["products", "deals_count"],
          "output": "price_trends"
        },
        {
          "type": "count_completions",
          "sources": ["scripts_drafted", "emails_triaged", "meetings_attended", "issues_resolved"],
          "output": "achievement_counts"
        }
      ],
      "description": "Aggregate and compute weekly statistics across all data sources",
      "on_error": "continue"
    },
    {
      "step": 7,
      "action": "llm_analyze",
      "prompt": "You are a weekly review analyst. Synthesize 5 days of daily briefs, focus sessions, price tracking, and content production into a weekly digest.\n\nStructure:\n1. WEEK AT A GLANCE: Key numbers (emails handled, meetings, focus hours, issues resolved)\n2. TOP ACHIEVEMENTS: What got done this week (max 5)\n3. PATTERNS: Recurring themes, bottlenecks, or trends spotted across the week\n4. PRICE ALERTS: Any notable price drops or deals from tracked items\n5. CONTENT STATUS: Scripts drafted, posts published\n6. NEXT WEEK PRIORITIES: Top 3 things to focus on based on this week's patterns\n\nBe data-driven. Reference specific numbers. Flag anything that got worse week-over-week.",
      "input_field": "aggregated_data",
      "description": "Synthesize weekly data into an actionable digest",
      "timeout_ms": 30000,
      "on_error": "fail",
      "evidence_capture": {
        "type": "llm_output",
        "label": "weekly-synthesis"
      }
    },
    {
      "step": 8,
      "action": "generate_report",
      "format": "markdown",
      "template": "# Weekly Digest — Week of {week_start}\n\n{analysis}\n\n---\n## Raw Stats\n- Morning briefs collected: {brief_count}/5\n- Focus sessions: {focus_count} ({focus_hours}h total)\n- Products tracked: {products_count}\n- Scripts drafted: {scripts_count}\n\n*Generated by Solace Browser · Weekly Digest v1.0*",
      "description": "Generate formatted weekly digest report",
      "on_error": "fail"
    },
    {
      "step": 9,
      "action": "save_to_outbox",
      "filename": "weekly-digest-{week_start}.json",
      "also_save_as": "weekly-digest-latest.json",
      "description": "Save weekly digest to outbox",
      "on_error": "fail",
      "evidence_capture": {
        "type": "output_hash",
        "label": "weekly-digest-saved"
      }
    },
    {
      "step": 10,
      "action": "return_result",
      "description": "Return the weekly digest with trends and priorities"
    }
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "week_start": {"type": "string", "format": "date"},
      "week_end": {"type": "string", "format": "date"},
      "achievements": {
        "type": "array",
        "items": {"type": "string"},
        "maxItems": 5
      },
      "next_week_priorities": {
        "type": "array",
        "items": {"type": "string"},
        "maxItems": 3
      },
      "stats": {
        "type": "object",
        "properties": {
          "emails_triaged": {"type": "integer"},
          "meetings_attended": {"type": "integer"},
          "focus_hours": {"type": "number"},
          "focus_sessions": {"type": "integer"},
          "issues_resolved": {"type": "integer"},
          "scripts_drafted": {"type": "integer"},
          "deals_found": {"type": "integer"}
        }
      },
      "briefs_collected": {"type": "integer"},
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["week_start", "achievements", "next_week_priorities", "timestamp"]
  },
  "budgets": {
    "max_reads": 50,
    "max_sends": 0,
    "max_deletes": 0,
    "max_llm_calls": 1,
    "max_cost_per_run_usd": 0.15
  },
  "error_handling": {
    "on_missing_briefs": "continue_with_available",
    "on_sub_app_failure": "continue_with_partial_data",
    "on_llm_failure": "return_raw_stats",
    "on_timeout": "save_partial_digest",
    "max_retries": 0
  },
  "metadata": {
    "tags": ["weekly", "digest", "review", "orchestrator", "multi-app", "llm"],
    "difficulty": "medium",
    "estimated_duration_s": 45,
    "idempotent": true,
    "destructive": false
  }
}
