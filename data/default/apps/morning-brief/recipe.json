{
  "id": "morning-brief",
  "platform": "multi-site",
  "version": "1.0.0",
  "type": "orchestrator",
  "description": "Orchestrate the daily morning brief by collecting outputs from Gmail, Calendar, GitHub Issues, Slack, Twitter, and Reddit, then synthesizing a prioritized daily summary with action items.",
  "oauth3_scopes": ["local.evidence"],
  "evidence_type": "lane_a",
  "input_params": {
    "include_social": {
      "type": "boolean",
      "description": "Whether to include Twitter and Reddit signals. Default true.",
      "required": false,
      "default": true
    },
    "priority_threshold": {
      "type": "string",
      "description": "Minimum priority to include: low, medium, high. Default 'low'.",
      "required": false,
      "default": "low"
    }
  },
  "steps": [
    {
      "step": 1,
      "action": "record_timestamp",
      "field": "brief_start",
      "description": "Record brief generation start time",
      "timeout_ms": 1000,
      "on_error": "fail"
    },
    {
      "step": 2,
      "action": "invoke_app",
      "app_id": "gmail-inbox-triage",
      "params": {"limit": 20},
      "description": "Collect today's unread emails with priority signals",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "gmail-brief-data"
      }
    },
    {
      "step": 3,
      "action": "invoke_app",
      "app_id": "calendar-brief",
      "params": {"days_ahead": 1},
      "description": "Collect today's calendar events and free slots",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "calendar-brief-data"
      }
    },
    {
      "step": 4,
      "action": "invoke_app",
      "app_id": "github-issue-triage",
      "description": "Collect assigned GitHub issues and new mentions",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "github-brief-data"
      }
    },
    {
      "step": 5,
      "action": "invoke_app",
      "app_id": "slack-triage",
      "description": "Collect unread Slack messages and channel highlights",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "slack-brief-data"
      }
    },
    {
      "step": 6,
      "action": "conditional",
      "condition": "{params.include_social}",
      "if_true": [
        {
          "action": "load_latest_outbox",
          "app_id": "twitter-monitor",
          "description": "Load latest Twitter monitoring results"
        },
        {
          "action": "load_latest_outbox",
          "app_id": "reddit-scanner",
          "description": "Load latest Reddit scanning results"
        }
      ],
      "description": "Optionally include social media signals from Twitter and Reddit",
      "timeout_ms": 10000,
      "on_error": "continue"
    },
    {
      "step": 7,
      "action": "llm_analyze",
      "prompt": "You are a personal executive assistant. Synthesize the following data sources into a concise morning brief.\n\nFor each item, assign priority: HIGH (needs action today), MEDIUM (this week), LOW (awareness only).\n\nStructure:\n1. TODAY'S SCHEDULE: Meetings with times, conflicts flagged\n2. URGENT ITEMS: Emails/issues/messages requiring same-day response\n3. ACTIVE WORK: GitHub issues assigned, pending reviews\n4. SOCIAL SIGNALS: Notable mentions or trending topics (if included)\n5. TOP 3 ACTIONS: The three most important things to do today\n\nBe concise. Use bullet points. Flag conflicts between meetings and deadlines.",
      "input_field": "collected_data",
      "description": "Synthesize all collected data into a prioritized morning brief",
      "timeout_ms": 30000,
      "on_error": "fail",
      "evidence_capture": {
        "type": "llm_output",
        "label": "brief-synthesis"
      }
    },
    {
      "step": 8,
      "action": "generate_report",
      "format": "markdown",
      "template": "# Morning Brief — {date}\n\n{analysis}\n\n---\n## Data Sources\n- Gmail: {gmail_count} emails\n- Calendar: {calendar_count} events\n- GitHub: {github_count} issues\n- Slack: {slack_count} messages\n{social_section}\n\n*Generated by Solace Browser · Morning Brief v1.0*",
      "description": "Generate formatted morning brief report",
      "on_error": "fail"
    },
    {
      "step": 9,
      "action": "save_to_outbox",
      "filename": "morning-brief-{date}.json",
      "description": "Save morning brief to outbox for downstream apps and weekly digest",
      "on_error": "fail",
      "evidence_capture": {
        "type": "output_hash",
        "label": "morning-brief-saved"
      }
    },
    {
      "step": 10,
      "action": "return_result",
      "description": "Return the synthesized morning brief"
    }
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "date": {"type": "string", "format": "date"},
      "schedule": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "time": {"type": "string"},
            "title": {"type": "string"},
            "has_conflict": {"type": "boolean"}
          }
        }
      },
      "urgent_items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "source": {"type": "string"},
            "title": {"type": "string"},
            "priority": {"type": "string"}
          }
        }
      },
      "top_actions": {
        "type": "array",
        "items": {"type": "string"},
        "maxItems": 3
      },
      "data_sources_summary": {
        "type": "object",
        "properties": {
          "gmail_count": {"type": "integer"},
          "calendar_count": {"type": "integer"},
          "github_count": {"type": "integer"},
          "slack_count": {"type": "integer"}
        }
      },
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["date", "top_actions", "timestamp"]
  },
  "budgets": {
    "max_reads": 150,
    "max_sends": 0,
    "max_deletes": 0,
    "max_llm_calls": 1,
    "max_cost_per_run_usd": 0.15
  },
  "error_handling": {
    "on_sub_app_failure": "continue_with_partial_data",
    "on_all_sub_apps_failed": "fail_with_evidence",
    "on_llm_failure": "return_raw_data",
    "on_timeout": "save_partial_brief",
    "max_retries": 0
  },
  "metadata": {
    "tags": ["morning", "brief", "daily", "orchestrator", "multi-app", "llm"],
    "difficulty": "medium",
    "estimated_duration_s": 90,
    "idempotent": true,
    "destructive": false
  }
}
