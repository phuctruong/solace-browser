{
  "id": "lead-pipeline",
  "platform": "multi-site",
  "version": "1.0.0",
  "type": "orchestrator",
  "description": "Orchestrate the lead pipeline by collecting LinkedIn outreach responses, Gmail follow-ups, and calendar availability, then producing a prioritized lead status report with next actions.",
  "oauth3_scopes": ["local.evidence"],
  "evidence_type": "lane_a",
  "input_params": {
    "pipeline_name": {
      "type": "string",
      "description": "Name of the pipeline (e.g., 'Q1 Outreach'). Default 'default'.",
      "required": false,
      "default": "default"
    },
    "max_leads": {
      "type": "integer",
      "description": "Maximum number of leads to process. Default 50.",
      "required": false,
      "default": 50
    }
  },
  "steps": [
    {
      "step": 1,
      "action": "invoke_app",
      "app_id": "linkedin-outreach",
      "description": "Collect latest LinkedIn outreach responses and connection request statuses",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "linkedin-outreach-data"
      }
    },
    {
      "step": 2,
      "action": "invoke_app",
      "app_id": "gmail-inbox-triage",
      "params": {
        "limit": 30,
        "filter": "label:leads OR label:outreach"
      },
      "description": "Collect lead-related email threads from Gmail",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "gmail-lead-data"
      }
    },
    {
      "step": 3,
      "action": "invoke_app",
      "app_id": "calendar-brief",
      "params": {
        "days_ahead": 7
      },
      "description": "Get calendar availability for the next 7 days for scheduling",
      "timeout_ms": 60000,
      "on_error": "continue",
      "evidence_capture": {
        "type": "sub_recipe_result",
        "label": "calendar-availability"
      }
    },
    {
      "step": 4,
      "action": "load_previous",
      "path": "outbox/lead-pipeline-latest.json",
      "description": "Load previous pipeline state for status change detection",
      "timeout_ms": 5000,
      "on_error": "continue"
    },
    {
      "step": 5,
      "action": "transform",
      "operations": [
        {
          "type": "merge_by_key",
          "sources": ["linkedin_data", "gmail_data"],
          "key": "contact_name",
          "output": "merged_leads"
        },
        {
          "type": "classify_stage",
          "stages": ["new", "contacted", "replied", "meeting_scheduled", "proposal_sent", "won", "lost"],
          "rules": {
            "replied": "has_email_reply OR has_linkedin_reply",
            "meeting_scheduled": "has_calendar_event",
            "contacted": "has_outreach_sent AND NOT has_reply"
          }
        },
        {
          "type": "sort",
          "by": "last_activity_date",
          "order": "descending"
        },
        {
          "type": "limit",
          "count": "{params.max_leads}"
        },
        {
          "type": "compute_next_action",
          "rules": {
            "contacted_no_reply_3d": "Send follow-up email",
            "replied_no_meeting": "Propose meeting time",
            "meeting_scheduled": "Prepare agenda",
            "stale_7d": "Move to nurture or close"
          }
        }
      ],
      "description": "Merge data sources, classify lead stages, and compute next actions",
      "on_error": "fail"
    },
    {
      "step": 6,
      "action": "generate_report",
      "format": "markdown",
      "template": "# Lead Pipeline — {params.pipeline_name} — {date}\n\n## Summary\n- Total leads: {total_leads}\n- New replies: {new_replies}\n- Meetings this week: {meetings_count}\n- Stale (>7d): {stale_count}\n\n## Leads by Stage\n{stage_breakdown}\n\n## Action Items\n{action_items}\n\n## Available Meeting Slots\n{free_slots}\n\n---\n*Generated by Solace Browser · Lead Pipeline v1.0*",
      "description": "Generate lead pipeline status report",
      "on_error": "fail"
    },
    {
      "step": 7,
      "action": "save_to_outbox",
      "filename": "lead-pipeline-{date}.json",
      "also_save_as": "lead-pipeline-latest.json",
      "description": "Save pipeline report to outbox",
      "on_error": "fail",
      "evidence_capture": {
        "type": "output_hash",
        "label": "pipeline-report-saved"
      }
    },
    {
      "step": 8,
      "action": "return_result",
      "description": "Return lead pipeline summary with stage breakdown and next actions"
    }
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "pipeline_name": {"type": "string"},
      "leads": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "contact_name": {"type": "string"},
            "company": {"type": "string"},
            "stage": {"type": "string"},
            "last_activity": {"type": "string"},
            "next_action": {"type": "string"},
            "source": {"type": "string"}
          },
          "required": ["contact_name", "stage", "next_action"]
        }
      },
      "stage_counts": {
        "type": "object",
        "additionalProperties": {"type": "integer"}
      },
      "stale_count": {"type": "integer"},
      "new_replies": {"type": "integer"},
      "meetings_this_week": {"type": "integer"},
      "total_leads": {"type": "integer"},
      "timestamp": {"type": "string", "format": "date-time"}
    },
    "required": ["pipeline_name", "leads", "total_leads", "timestamp"]
  },
  "budgets": {
    "max_reads": 100,
    "max_sends": 0,
    "max_deletes": 0,
    "max_llm_calls": 1,
    "max_cost_per_run_usd": 0.10
  },
  "error_handling": {
    "on_sub_app_failure": "continue_with_partial_data",
    "on_merge_conflict": "prefer_latest",
    "on_timeout": "save_partial_report",
    "max_retries": 0
  },
  "metadata": {
    "tags": ["leads", "sales", "pipeline", "orchestrator", "multi-app"],
    "difficulty": "hard",
    "estimated_duration_s": 120,
    "idempotent": true,
    "destructive": false
  }
}
