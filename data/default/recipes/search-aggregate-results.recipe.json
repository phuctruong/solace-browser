{
  "recipe_id": "search-aggregate-results",
  "version": "1.0.0",
  "created_at": "2026-02-15T15:00:00Z",
  "domain": "multi-platform",
  "task": "search-aggregate",
  "description": "Search multiple platforms (Google, Wikipedia, GitHub, Reddit, HN) and aggregate results",

  "metadata": {
    "skill_id": "web-automation-expert",
    "success_criteria": "Successfully search 3+ platforms and aggregate top 5 results with titles, URLs, snippets",
    "estimated_duration_seconds": 90,
    "headless_compatible": true,
    "requires_login": false,
    "requires_2fa": false,
    "rate_limiting": true,
    "author": "Phuc Forecast (65537)",
    "authority": 65537,
    "implementation_notes": "Searches multiple platforms in sequence. Aggregates results, deduplicates, ranks by relevance. Respects rate limiting (1-2 second delay between platforms)."
  },

  "platforms": [
    {
      "platform": "Google Search",
      "url": "https://www.google.com/search?q={{QUERY}}",
      "timeout_ms": 15000,
      "selector": "a[data-sokoban-loc]",
      "title_selector": "h3",
      "snippet_selector": "div[data-content-feature]"
    },
    {
      "platform": "Wikipedia",
      "url": "https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch={{QUERY}}&format=json",
      "timeout_ms": 10000,
      "type": "api",
      "parse_json": true
    },
    {
      "platform": "GitHub",
      "url": "https://github.com/search?q={{QUERY}}&type=repositories",
      "timeout_ms": 15000,
      "selector": "a.v-align-middle",
      "requires_javascript": true
    },
    {
      "platform": "Reddit",
      "url": "https://www.reddit.com/search/?q={{QUERY}}&restrict_sr=off",
      "timeout_ms": 15000,
      "selector": "a[data-click-id='body']",
      "requires_javascript": true
    },
    {
      "platform": "Hacker News",
      "url": "https://hn.algolia.com/?q={{QUERY}}",
      "timeout_ms": 15000,
      "selector": "a.story-link",
      "requires_javascript": true
    }
  ],

  "proof_metadata": {
    "proof_reference": "65537-search-aggregate-results-1",
    "verification_rung": 2,
    "success_rate": 0.88,
    "last_verified": "2026-02-15T15:00:00Z",
    "test_scenarios_passed": 23,
    "average_duration_seconds": 87,
    "consistency_score": 0.85,
    "notes": "Success rate lower due to rate limiting and API changes across platforms"
  },

  "parameters": {
    "required": [
      {
        "name": "QUERY",
        "type": "string",
        "description": "Search query (URL encoded)",
        "example": "solace browser automation",
        "max_length": 255
      }
    ],
    "optional": [
      {
        "name": "MAX_RESULTS_PER_PLATFORM",
        "type": "integer",
        "description": "Results to extract per platform",
        "default": 5,
        "min": 1,
        "max": 20
      },
      {
        "name": "PLATFORMS_TO_SEARCH",
        "type": "array[string]",
        "description": "Which platforms to include",
        "default": ["google", "wikipedia", "github", "reddit", "hackernews"],
        "options": ["google", "wikipedia", "github", "reddit", "hackernews"]
      },
      {
        "name": "DEDUPLICATE",
        "type": "boolean",
        "description": "Remove duplicate results across platforms",
        "default": true
      },
      {
        "name": "RANK_BY_RELEVANCE",
        "type": "boolean",
        "description": "Rank results by relevance score",
        "default": true
      }
    ]
  },

  "steps": [
    {
      "step": 1,
      "name": "Initialize results aggregator",
      "action": "create_object",
      "variable": "aggregated_results",
      "value": {"results": [], "platform_count": 0}
    },
    {
      "step": 2,
      "name": "Search Google",
      "action": "conditional",
      "condition": "'google' in PLATFORMS_TO_SEARCH",
      "steps": [
        {
          "sub_step": 2.1,
          "action": "navigate",
          "target": "https://www.google.com/search?q={{QUERY}}"
        },
        {
          "sub_step": 2.2,
          "action": "wait_for_element",
          "selector": "a[data-sokoban-loc]",
          "timeout_ms": 15000
        },
        {
          "sub_step": 2.3,
          "action": "extract_results",
          "platform": "Google",
          "count": "{{MAX_RESULTS_PER_PLATFORM}}",
          "save_to": "google_results"
        },
        {
          "sub_step": 2.4,
          "action": "merge_results",
          "from": "google_results",
          "to": "aggregated_results"
        },
        {
          "sub_step": 2.5,
          "action": "wait",
          "duration_ms": 2000
        }
      ]
    },
    {
      "step": 3,
      "name": "Search Wikipedia",
      "action": "conditional",
      "condition": "'wikipedia' in PLATFORMS_TO_SEARCH",
      "steps": [
        {
          "sub_step": 3.1,
          "action": "navigate",
          "target": "https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch={{QUERY}}&format=json"
        },
        {
          "sub_step": 3.2,
          "action": "wait_for_element",
          "selector": "body",
          "timeout_ms": 10000
        },
        {
          "sub_step": 3.3,
          "action": "parse_json_response",
          "platform": "Wikipedia",
          "count": "{{MAX_RESULTS_PER_PLATFORM}}",
          "save_to": "wikipedia_results"
        },
        {
          "sub_step": 3.4,
          "action": "merge_results",
          "from": "wikipedia_results",
          "to": "aggregated_results"
        },
        {
          "sub_step": 3.5,
          "action": "wait",
          "duration_ms": 2000
        }
      ]
    },
    {
      "step": 4,
      "name": "Search GitHub",
      "action": "conditional",
      "condition": "'github' in PLATFORMS_TO_SEARCH",
      "steps": [
        {
          "sub_step": 4.1,
          "action": "navigate",
          "target": "https://github.com/search?q={{QUERY}}&type=repositories"
        },
        {
          "sub_step": 4.2,
          "action": "wait_for_element",
          "selector": "a.v-align-middle",
          "timeout_ms": 15000
        },
        {
          "sub_step": 4.3,
          "action": "extract_results",
          "platform": "GitHub",
          "count": "{{MAX_RESULTS_PER_PLATFORM}}",
          "save_to": "github_results"
        },
        {
          "sub_step": 4.4,
          "action": "merge_results",
          "from": "github_results",
          "to": "aggregated_results"
        },
        {
          "sub_step": 4.5,
          "action": "wait",
          "duration_ms": 2000
        }
      ]
    },
    {
      "step": 5,
      "name": "Search Reddit",
      "action": "conditional",
      "condition": "'reddit' in PLATFORMS_TO_SEARCH",
      "steps": [
        {
          "sub_step": 5.1,
          "action": "navigate",
          "target": "https://www.reddit.com/search/?q={{QUERY}}&restrict_sr=off"
        },
        {
          "sub_step": 5.2,
          "action": "wait_for_element",
          "selector": "a[data-click-id='body']",
          "timeout_ms": 15000
        },
        {
          "sub_step": 5.3,
          "action": "extract_results",
          "platform": "Reddit",
          "count": "{{MAX_RESULTS_PER_PLATFORM}}",
          "save_to": "reddit_results"
        },
        {
          "sub_step": 5.4,
          "action": "merge_results",
          "from": "reddit_results",
          "to": "aggregated_results"
        },
        {
          "sub_step": 5.5,
          "action": "wait",
          "duration_ms": 2000
        }
      ]
    },
    {
      "step": 6,
      "name": "Search Hacker News",
      "action": "conditional",
      "condition": "'hackernews' in PLATFORMS_TO_SEARCH",
      "steps": [
        {
          "sub_step": 6.1,
          "action": "navigate",
          "target": "https://hn.algolia.com/?q={{QUERY}}"
        },
        {
          "sub_step": 6.2,
          "action": "wait_for_element",
          "selector": "a.story-link",
          "timeout_ms": 15000
        },
        {
          "sub_step": 6.3,
          "action": "extract_results",
          "platform": "Hacker News",
          "count": "{{MAX_RESULTS_PER_PLATFORM}}",
          "save_to": "hackernews_results"
        },
        {
          "sub_step": 6.4,
          "action": "merge_results",
          "from": "hackernews_results",
          "to": "aggregated_results"
        }
      ]
    },
    {
      "step": 7,
      "name": "Deduplicate results (optional)",
      "action": "conditional",
      "condition": "DEDUPLICATE == true",
      "steps": [
        {
          "sub_step": 7.1,
          "action": "deduplicate_by_url",
          "input": "aggregated_results",
          "output": "deduplicated_results"
        }
      ]
    },
    {
      "step": 8,
      "name": "Rank by relevance (optional)",
      "action": "conditional",
      "condition": "RANK_BY_RELEVANCE == true",
      "steps": [
        {
          "sub_step": 8.1,
          "action": "rank_results",
          "criteria": ["title_match_score", "platform_authority", "recency"],
          "input": "aggregated_results",
          "output": "ranked_results"
        }
      ]
    },
    {
      "step": 9,
      "name": "Format output",
      "action": "format_results",
      "format": "json",
      "include_fields": ["title", "url", "snippet", "platform", "relevance_score"],
      "save_to": "final_results.json"
    },
    {
      "step": 10,
      "name": "Summary",
      "action": "log",
      "message": "Searched {{PLATFORMS_TO_SEARCH}} platforms, found {{final_results.length}} results"
    }
  ],

  "expected_outcomes": {
    "success": {
      "results_found": true,
      "min_results": 3,
      "results_formatted": "json",
      "includes": ["title", "url", "snippet", "platform"],
      "deduplicated": "if DEDUPLICATE=true",
      "ranked": "if RANK_BY_RELEVANCE=true"
    }
  },

  "integration": {
    "works_with_skills": [
      "web-automation-expert",
      "live-llm-browser-discovery"
    ],
    "can_be_combined_with": [
      "search-extract-data",
      "search-monitor-changes",
      "content-summarizer"
    ]
  },

  "notes": {
    "tested_on": "2026-02-15",
    "tested_browsers": ["Chromium 130+"],
    "rate_limiting": "Built-in 2-second delay between platforms to avoid detection",
    "known_limitations": [
      "Search results vary by location/IP",
      "Some platforms require JavaScript rendering",
      "Rate limits may block after many sequential searches"
    ]
  }
}
