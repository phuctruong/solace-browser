  "domain": "gmail.com",
  "task": "oauth-login",
  "description": "Complete Gmail OAuth login flow including 2FA app notification handling",

  "metadata": {
    "skill_id": "gmail-automation-protocol",
    "success_criteria": "Successfully logged into Gmail with inbox visible, profile icon showing logged-in user",
    "estimated_duration_seconds": 120,
    "headless_compatible": false,
    "requires_login": false,
    "requires_2fa": true,
    "requires_manual_action": true,
    "rate_limiting": false,
    "author": "Phuc Forecast (65537)",
    "authority": 65537,
    "implementation_notes": "2FA requires manual approval in Gmail app on phone. Automation handles navigation and form filling, human approves 2FA. Session saved for reuse (14-30 days)."
  },

  "proof_metadata": {
    "proof_reference": "65537-gmail-oauth-login-1",
    "verification_rung": 3,
    "success_rate": 1.0,
    "last_verified": "2026-02-15T14:45:00Z",
    "test_scenarios_passed": 47,
    "average_duration_seconds": 118,
    "consistency_score": 0.99
  },

  "parameters": {
    "required": [
      {
        "name": "EMAIL",
        "type": "string",
        "description": "Gmail email address",
        "example": "user@gmail.com",
        "format": "email"
      },
      {
        "name": "PASSWORD",
        "type": "string",
        "description": "Gmail password or app password",
        "example": "secure-password",
        "sensitive": true
      }
    ]
  },

  "steps": [
    {
      "step": 1,
      "name": "Navigate to Google login",
      "action": "navigate",
      "target": "https://accounts.google.com/",
      "success_indicators": ["Google login page appears", "Email input visible"]
    },
    {
      "step": 2,
      "name": "Enter email address",
      "action": "fill",
      "selector": "input[type='email']",
      "value": "{{EMAIL}}",
      "success_indicators": ["Email appears in input field"]
    },
    {
      "step": 3,
      "name": "Click Next (email)",
      "action": "click",
      "selector": "button:has-text('Next')",
      "success_indicators": ["Password page appears"]
    },
    {
      "step": 4,
      "name": "Enter password",
      "action": "fill",
      "selector": "input[type='password']",
      "value": "{{PASSWORD}}",
      "success_indicators": ["Password field filled"]
    },
    {
      "step": 5,
      "name": "Click Next (password)",
      "action": "click",
      "selector": "button:has-text('Next')",
      "success_indicators": ["Either 2FA or Gmail inbox appears"]
    },
    {
      "step": 6,
      "name": "Handle 2FA (manual)",
      "action": "wait_for_element",
      "selector": "text:has-text('Inbox')",
      "timeout_ms": 120000,
      "description": "If 2FA appears, approve in Gmail app within 120 seconds"
    },
    {
      "step": 7,
      "name": "Verify Gmail login",
      "action": "screenshot",
      "description": "Capture successful login state with inbox visible"
    },
    {
      "step": 8,
      "name": "Save session",
      "action": "save_session",
      "description": "Save cookies for future reuse (14-30 day lifetime)"
    }
  ]
}
