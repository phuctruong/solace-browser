{
  "name": "Gmail Compose Email",
  "description": "Compose and send an email via Gmail using Phase 4 AutomationAPI",
  "refmap_source": "refmap_gmail.json",
  "steps": [
    {
      "action": "clickButton",
      "ref_id": "ref_02444543",
      "description": "Click Compose button"
    },
    {
      "action": "wait",
      "duration": 1000,
      "description": "Wait for compose window to open"
    },
    {
      "action": "fillField",
      "ref_id": "ref_d108e29f",
      "value": "user@example.com",
      "description": "Fill To field with recipient email"
    },
    {
      "action": "verifyInteraction",
      "ref_id": "ref_d108e29f",
      "expected_state": { "value": "user@example.com" },
      "description": "Verify To field was filled"
    },
    {
      "action": "fillField",
      "ref_id": "ref_4a861bf2",
      "value": "Meeting tomorrow",
      "description": "Fill Subject field"
    },
    {
      "action": "verifyInteraction",
      "ref_id": "ref_4a861bf2",
      "expected_state": { "value": "Meeting tomorrow" },
      "description": "Verify Subject field was filled"
    },
    {
      "action": "typeText",
      "ref_id": "ref_32460a2e",
      "text": "Hi, can we meet tomorrow at 2pm?\n\nBest regards",
      "shift_handling": { "autoShift": true, "dispatchKeyEvents": true },
      "description": "Type message body with shift handling for capitals"
    },
    {
      "action": "clickButton",
      "ref_id": "ref_a13d2480",
      "description": "Click Send button"
    }
  ],
  "value_map": {
    "ref_d108e29f": "user@example.com",
    "ref_4a861bf2": "Meeting tomorrow",
    "ref_32460a2e": "Hi, can we meet tomorrow at 2pm?\n\nBest regards"
  }
}
