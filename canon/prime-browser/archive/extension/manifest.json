{
  "manifest_version": 3,
  "name": "Solace Browser Bridge",
  "version": "1.0.0",
  "description": "Browser control and recording for Solace CLI (Prime Browser) — Twin AI + Playwright recipes",
  "permissions": [
    "scripting",
    "webRequest",
    "tabs",
    "storage",
    "debugger",
    "webNavigation",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["captcha_handler.js", "content_captcha_integration.js", "automation_api.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Solace Browser Control",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "options_page": "options.html"
}
